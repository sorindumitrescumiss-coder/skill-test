NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

OPENROUTER_API_KEY=YOUR_OPENROUTER_API_KEY
OPENROUTER_MODEL=openai/gpt-4o-mini

# Public site URL (no trailing slash). Local dev default; in production set to your real domain, e.g.:
# NEXT_PUBLIC_SITE_URL=https://trueassess.abrdns.com
# Used for OpenRouter referer and should match the URL users open in the browser.
NEXT_PUBLIC_SITE_URL=http://localhost:4028

# Profile API: persist wallet to DB only if column exists. Default off (no wallet column required).
# After running supabase/skill_test_nft_mints.sql, set to true to save / read profiles.wallet_address.
PROFILE_SYNC_INCLUDE_WALLET=false

# Admin-only routes: comma-separated sign-in emails (server-side).
ADMIN_EMAILS=admin@example.com

# thirdweb mint UI (admin /admin/create-nft)
NEXT_PUBLIC_THIRDWEB_CLIENT_ID=
NEXT_PUBLIC_NFT_CONTRACT_ADDRESS=
# Chain id where the NFT collection is deployed (e.g. Base Sepolia 84532, Polygon 137)
NEXT_PUBLIC_CHAIN_ID=84532

# ── Server NFT mint (after skill test submit and/or certificate claim) ──
NFT_SERVER_MINT_ENABLED=false
NFT_MINT_MIN_SCORE=86
# Fire thirdweb mint from API when these are true:
NFT_MINT_ON_SUBMIT=false
NFT_MINT_ON_CLAIM=true
# Minter wallet must be allowed to mint on the collection contract.
NFT_MINTER_PRIVATE_KEY=
# Prefer on the server; fallback to NEXT_PUBLIC_THIRDWEB_CLIENT_ID.
THIRDWEB_SECRET_KEY=
NFT_DEFAULT_IMAGE_URL=
NFT_CREDENTIAL_NAME_TEMPLATE=TrueAssess Credential {id}
